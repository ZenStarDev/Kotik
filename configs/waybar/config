{
  "layer": "top",
  "position": "top",
  "modules-left": ["sway/workspaces", "sway/mode"],
  "modules-center": ["sway/window"],
  "modules-right": ["network", "pulseaudio", "cpu", "memory", "clock"],
  "clock": {
    "format": "%a %b %d %H:%M"
  },
  "cpu": {
    "format": "CPU {usage}%"
  },
  "memory": {
    "format": "RAM {used}MiB"
  }
}